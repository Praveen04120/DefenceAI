# ============================================================
# DefenceAI — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ─── AI API Key ──────────────────────────────────────────────
API_KEY=your_ai_api_key_here

# ─── Supabase ─────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── Security ─────────────────────────────────────────────────
# Admin panel password (used as x-admin-secret header)
ADMIN_SECRET=choose-a-strong-secret-here

# Vercel Cron Job authorization key (set in Vercel env too)
CRON_SECRET=choose-a-cron-secret-here

# ─── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
